
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Маълумоти шахсии корбар ва ҳолати верификатсия",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["Usto", "Client"] },
        "phone": { "type": "string" },
        "region": { "type": "string" },
        "balance": { "type": "number" },
        "identificationStatus": { "type": "string", "enum": ["None", "Pending", "Verified", "Rejected", "Blocked"] },
        "kycSubmittedAt": { "type": "string", "format": "date-time" },
        "errorReason": { "type": "string" }
      }
    },
    "VerificationRequest": {
      "title": "VerificationRequest",
      "description": "Дархости верификатсия бо суратҳои паспорт ва чек",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhone": { "type": "string" },
        "photos": { "type": "array", "items": { "type": "string" } },
        "receipt": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Reviewed"] }
      }
    }
  },
  "auth": {
    "providers": ["email", "google"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Профилҳои корбарон"
    },
    "/verification_requests/{userId}": {
      "schema": "VerificationRequest",
      "description": "Маълумоти верификатсия ва навбати дархостҳо (KYC Queue)"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Эълонҳои устоҳо"
    }
  }
}
