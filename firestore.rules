rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Функсияҳо барои санҷиши ҳуқуқ
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Қоидаҳо барои Профилҳои корбарон
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId);
    }

    // Қоидаҳо барои Эълонҳо (Listings)
    match /listings/{listingId} {
      allow read: if true; // Ҳама метавонанд эълонҳоро бинанд
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Қоидаҳо барои Чатҳо
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        request.auth.uid == resource.data.artisanId ||
        request.auth.uid == request.resource.data.clientId ||
        request.auth.uid == request.resource.data.artisanId
      );
      
      // Паёмҳо дар дохили чат
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // Қоидаҳо барои Шартномаҳо (Deals)
    match /deals/{dealId} {
      allow read, write: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        request.auth.uid == resource.data.artisanId ||
        request.auth.uid == request.resource.data.clientId ||
        request.auth.uid == request.resource.data.artisanId
      );
    }

    // Қоидаҳо барои дархостҳои Premium ва Верификатсия
    match /premium_requests/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /verification_requests/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Қоидаҳо барои Транзаксияҳо ва Ҳамён
    match /transactions/{txId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
    }
    
    match /deposit_requests/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /withdrawal_requests/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}